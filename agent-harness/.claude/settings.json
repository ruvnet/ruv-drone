{
  "permissions": {
    "allow": [
      "Bash(npx ruvdrone*)",
      "mcp__ruvdrone__*",
      "mcp__code_index__*",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(git push*)",
      "Bash(rm -rf*)"
    ]
  },
  "mcpServers": {
    "ruvdrone": {
      "command": "npx",
      "args": [
        "-y",
        "ruvdrone@latest",
        "mcp",
        "start"
      ]
    },
    "code_index": {
      "command": "npx",
      "args": [
        "-y",
        "ruvdrone@latest",
        "mcp",
        "index"
      ]
    }
  }
}
