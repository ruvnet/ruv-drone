{
  "name": "ruvdrone",
  "version": "0.1.0",
  "description": "AI agent harness for ruv-drone — cooperative civilian UAV fleet coordination in Rust. Wired for all 9 hosts and verified against the real host runtimes.",
  "type": "module",
  "homepage": "https://github.com/ruvnet/ruv-drone/tree/main/agent-harness",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/ruv-drone.git",
    "directory": "agent-harness"
  },
  "bin": {
    "ruvdrone": "./bin/cli.js"
  },
  "files": [
    "bin/**", "dist/**", "src/**", "tsconfig.json",
    ".claude/**", "CLAUDE.md", "AGENTS.md", "SYSTEM.md",
    ".codex/**", ".opencode/**", ".vscode/**", ".openclaw/**",
    "cli-config.yaml", "optional-mcps/**", "rvm.manifest.toml", "capability-table.json",
    "trust.json", ".github/**", "docs/**", "README.md", "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "init": "node ./bin/cli.js init",
    "doctor": "node ./bin/cli.js doctor"
  },
  "keywords": [
    "agent-harness", "metaharness", "example", "ruv-drone", "uav", "drone-swarm",
    "rust", "formation-control", "raft-consensus", "path-planning",
    "claude-code", "codex", "opencode", "copilot", "github-actions",
    "hermes", "openclaw", "pi-dev", "rvm"
  ],
  "dependencies": {
    "@metaharness/kernel": "^0.1.0",
    "@metaharness/host-claude-code": "^0.1.1",
    "@metaharness/host-codex": "^0.1.1",
    "@metaharness/host-copilot": "^0.1.1",
    "@metaharness/host-github-actions": "^0.1.1",
    "@metaharness/host-hermes": "^0.1.1",
    "@metaharness/host-openclaw": "^0.1.1",
    "@metaharness/host-opencode": "^0.1.1",
    "@metaharness/host-pi-dev": "^0.1.1",
    "@metaharness/host-rvm": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
